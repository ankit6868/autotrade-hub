# App
APP_SECRET_KEY=generate-a-random-32-char-string-here
DATABASE_URL=sqlite:///./data/autotrade.db

# OpenRouter (FREE — get key at openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_DEFAULT_MODEL=qwen/qwen3-coder-480b:free

# Freqtrade paths
FREQTRADE_PATH=freqtrade
FREQTRADE_USERDIR=./user_data

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# KuCoin proxy (REQUIRED if backend is hosted in a US region — Railway,
# Vercel, most AWS US PoPs, etc. KuCoin geo-blocks US IPs with HTTP 451.
#
# Single proxy:
#   KUCOIN_HTTPS_PROXY=http://user:pass@host:port
#
# MULTIPLE proxies (recommended for resilience — Webshare's free tier
# rotates individual IPs daily, so a single URL eventually 407s. Paste
# all 10 from your Webshare dashboard, comma-separated, and the app
# automatically fails over to the next when one dies):
#   KUCOIN_HTTPS_PROXY=http://u:p@h1:1,http://u:p@h2:2,http://u:p@h3:3
#
# SOCKS5 also supported:
#   KUCOIN_HTTPS_PROXY=socks5://u:p@h:port   (needs httpx-socks)
#
# Leave blank if your backend already has a non-US egress IP.
KUCOIN_HTTPS_PROXY=
