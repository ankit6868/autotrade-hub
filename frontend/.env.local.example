# Get these from https://dashboard.clerk.com (free tier)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Where Clerk sends users
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/setup

# Backend API URL — REQUIRED for Vercel deployments
# Set this to your deployed backend URL (e.g. https://your-backend.railway.app)
# For local development, defaults to http://localhost:8000
BACKEND_URL=http://localhost:8000
