{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://autotrade-backend-production.up.railway.app/api/:path*" },
    { "source": "/ws/:path*", "destination": "https://autotrade-backend-production.up.railway.app/ws/:path*" }
  ]
}
