# Copy to `.env.prod`, fill in real values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- Required ---------------------------------------------------------------
APP_SECRET_KEY=                       # 32+ char random string. Encrypts user API keys.
POSTGRES_PASSWORD=                    # strong random string

# --- Clerk auth (omit to fall back to single anonymous user — NOT for prod) -
CLERK_JWKS_URL=                       # https://<your-clerk>.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=                         # https://<your-clerk>.clerk.accounts.dev
CLERK_AUDIENCE=                       # optional; only set if your Clerk app issues an aud claim
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Web exposure -----------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://app.example.com
FRONTEND_PORT=3000

# --- Optional: tighten rate limits ------------------------------------------
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_TRADE=20/minute
RATE_LIMIT_AI=30/minute
# Use redis://redis:6379 if you add a redis service for multi-instance limits.
RATE_LIMIT_STORAGE=memory://

# --- Optional: observability ------------------------------------------------
SENTRY_DSN=
APP_VERSION=1.0.0

# --- Optional: Postgres tuning ----------------------------------------------
POSTGRES_USER=tradebot
POSTGRES_DB=tradebot

# --- KuCoin proxy (REQUIRED on US-hosted PaaS like Railway) -----------------
# KuCoin returns HTTP 451 ("our services are currently unavailable in the
# U.S.") to every US egress IP. Set this to an HTTP/HTTPS/SOCKS5 proxy URL
# in a non-restricted region (SG/EU/JP/AU) and ALL KuCoin REST calls
# (Setup test, market data, candles, orders, account, Lead Trading) are
# routed through it. Leave blank in regions where KuCoin is reachable.
#   KUCOIN_HTTPS_PROXY=http://user:pass@host:port
#   KUCOIN_HTTPS_PROXY=socks5://user:pass@host:port  # needs httpx[socks]
KUCOIN_HTTPS_PROXY=
